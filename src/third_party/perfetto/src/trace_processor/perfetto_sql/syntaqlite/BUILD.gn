import("../../../../gn/test.gni")

assert(enable_perfetto_trace_processor_sqlite)

# Amalgamated C tokenizer + parser generated from `perfetto.y` (grammar)
# and `perfetto.synq` (AST node definitions) by `tools/gen_syntaqlite_parser`.
source_set("syntaqlite") {
  sources = [
    "syntaqlite_perfetto.c",
    "syntaqlite_perfetto.h",
    "utils.h",
  ]
  deps = [ "../../../../gn:default_deps" ]
  visibility = [
    "../../util:sql_module_doc_parser",
    "../parser:*",
    "../tokenizer",
  ]
}
