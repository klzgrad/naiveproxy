import("../../../gn/perfetto.gni")

source_set("regex") {
  sources = [
    "regex.cc",
    "regex_std.h",
  ]
  if (enable_perfetto_re2) {
    sources += [ "regex_re2.h" ]
  }
  if (enable_perfetto_pcre2) {
    sources += [ "regex_pcre2.h" ]
  }
  deps = [ "../../../gn:default_deps" ]
  public_deps = [
    "../../../include/perfetto/base",
    "../../../include/perfetto/ext/base",
    "../../../include/perfetto/ext/base:regex",
  ]
  if (enable_perfetto_re2) {
    public_deps += [ "../../../gn:re2" ]
  }
  if (enable_perfetto_pcre2) {
    public_deps += [ "../../../gn:pcre2" ]
  }
}
