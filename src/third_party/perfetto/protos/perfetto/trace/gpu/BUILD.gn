import("../../../../gn/proto_library.gni")

perfetto_proto_library("@TYPE@") {
  deps = [ "../../common:@TYPE@" ]
  sources = [
    "gpu_counter_event.proto",
    "gpu_log.proto",
    "gpu_mem_event.proto",
    "gpu_render_stage_event.proto",
    "vulkan_api_event.proto",
    "vulkan_memory_event.proto",
  ]
}

# GPU track_event extensions
perfetto_proto_library("gpu_track_event_@TYPE@") {
  sources = [ "gpu_track_event.proto" ]
  public_deps = [ "../track_event:@TYPE@" ]
  generator_visibility = [ "../../../../src/trace_processor/importers/proto:gen_cc_gpu_track_event_descriptor" ]
  generate_descriptor = "gpu_track_event.descriptor"
  descriptor_root_source = "gpu_track_event.proto"

  # This is the descriptor for an extension. It shouldn't include the descriptor
  # for the base message as well.
  exclude_imports = true
}

# GPU interned_data extensions
perfetto_proto_library("gpu_interned_data_@TYPE@") {
  sources = [ "gpu_interned_data.proto" ]
  deps = [ ":@TYPE@" ]
  public_deps = [ "../interned_data:@TYPE@" ]
  generator_visibility = [ "../../../../src/trace_processor/importers/proto:gen_cc_gpu_interned_data_descriptor" ]
  generate_descriptor = "gpu_interned_data.descriptor"
  descriptor_root_source = "gpu_interned_data.proto"

  # This is the descriptor for an extension. It shouldn't include the descriptor
  # for the base message as well.
  exclude_imports = true
}
